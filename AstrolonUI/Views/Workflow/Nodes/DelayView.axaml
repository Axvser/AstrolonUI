<local:NodeViewBase xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="130"
                    x:Class="AstrolonUI.DelayView"
                    xmlns:local="using:AstrolonUI"
                    xmlns:vm="using:AstrolonUI.ViewModels"
                    x:DataType="vm:DelayViewModel"
                    xmlns:behaviors="using:VeloxDev.WorkflowSystem.AttachedBehaviors"
                    behaviors:WorkflowSlotLayoutBehavior.IsEnabled="True"
                    behaviors:WorkflowSlotLayoutBehavior.SlotNames="PART_InputSlot,PART_OutputSlot"
                    behaviors:WorkflowSlotLayoutBehavior.CoordinateHostName="PART_Canvas">
    <Border CornerRadius="6" BoxShadow="0 2 12 rgba(0,0,0,0.25)">
        <Grid RowDefinitions="32,*,4">
            <Border Grid.Row="0"
                    Background="{Binding $parent[local:NodeViewBase].HeadBackground}"
                    CornerRadius="6,6,0,0"
                    behaviors:WorkflowNodeDragBehavior.CoordinateHostName="PART_Canvas"
                    behaviors:WorkflowNodeDragBehavior.IsEnabled="True">
                <TextBlock Text="{Binding Name}"
                           Foreground="{Binding $parent[local:NodeViewBase].HeadForeground}"
                           FontWeight="Bold"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <Grid Grid.Row="1" Background="{Binding $parent[local:NodeViewBase].HeadBackground}" ColumnDefinitions="18,*,18">
                <local:SlotView x:Name="PART_InputSlot"
                                Grid.Column="0"
                                Width="14" Height="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{Binding $parent[local:NodeViewBase].HeadForeground}"
                                DataContext="{Binding InputSlot}" />
                <StackPanel Grid.Column="1" Margin="10,8" Spacing="6">
                    <TextBox Text="{Binding DelayMilliseconds, Mode=TwoWay}"
                             FontFamily="Consolas"/>
                    <TextBlock Text="{Binding IsWaiting, StringFormat=Waiting: {0}}"
                               Foreground="{Binding $parent[local:NodeViewBase].HeadForeground}"
                               FontSize="11"/>
                </StackPanel>
                <local:SlotView x:Name="PART_OutputSlot"
                                Grid.Column="2"
                                Width="14" Height="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{Binding $parent[local:NodeViewBase].HeadForeground}"
                                DataContext="{Binding OutputSlot}" />
            </Grid>

            <local:ShellRunningIndicator Grid.Row="2" IsRunning="{Binding IsWaiting}"/>
        </Grid>
    </Border>
</local:NodeViewBase>
