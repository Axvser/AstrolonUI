<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:AstrolonUI.ViewModels"
			 xmlns:views="using:AstrolonUI"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="AstrolonUI.Views.MainView"
			 x:DataType="vm:MainViewModel">
	<Grid RowDefinitions="Auto,*">
		<Border Grid.Row="0"
				Background="Transparent"
				BorderBrush="#4c4c4c"
				BorderThickness="0,0,0,1"
				Padding="4,3">
			<Grid ColumnDefinitions="Auto,Auto,Auto,Auto,16,Auto,180,*"
				  VerticalAlignment="Center">
				<Menu Grid.Column="0"
					  Background="Transparent"
					  VerticalAlignment="Center">
					<MenuItem Header="文件">
						<MenuItem Header="新建工作区"
								  Click="NewWorkflow_Click"/>
						<MenuItem Header="打开..."
								  Click="OpenWorkflow_Click"/>
						<Separator/>
						<MenuItem Header="保存"
								  Click="SaveWorkflow_Click"/>
						<MenuItem Header="另存为..."
								  Click="SaveWorkflowAs_Click"/>
					</MenuItem>
				</Menu>

				<Button Grid.Column="1"
						Content="撤销"
						MinWidth="56"
						Command="{Binding Tree.UndoCommand}"/>
				<Button Grid.Column="2"
						Content="重做"
						MinWidth="56"
						Command="{Binding Tree.RedoCommand}"/>
				<Button Grid.Column="3"
						Content="主题"
						MinWidth="56"
						Command="{Binding ReverseThemeCommand}"/>

				<TextBlock Grid.Column="5"
						   Text="工作区"
						   VerticalAlignment="Center"
						   Margin="0,0,8,0"/>
				<ComboBox Grid.Column="6"
						  ItemsSource="{Binding Workspaces}"
						  SelectedItem="{Binding Tree, Mode=TwoWay}"
						  SelectionChanged="WorkspaceSelectionChanged"
						  HorizontalAlignment="Stretch">
					<ComboBox.ItemTemplate>
						<DataTemplate DataType="vm:TreeViewModel">
							<TextBlock Text="{Binding WorkspaceName}"
									   TextTrimming="CharacterEllipsis"
									   ToolTip.Tip="{Binding LocalPath}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>

				<TextBlock Grid.Column="7"
						   Text="{Binding StatusMessage}"
						   Opacity="0.65"
						   VerticalAlignment="Center"
						   HorizontalAlignment="Right"
						   TextTrimming="CharacterEllipsis"
						   MaxWidth="320"
						   Margin="12,0,6,0"/>
			</Grid>
		</Border>

		<Grid Grid.Row="1" ColumnDefinitions="360,5,*">
			<Grid Grid.Column="0"
				  RowDefinitions="2*,Auto,4*,2*"
				  RowSpacing="8">
					<Border Grid.Row="0"
							Padding="10"
							Background="Transparent"
							BorderBrush="#4c4c4c"
							BorderThickness="1"
							CornerRadius="4">
						<Grid RowDefinitions="Auto,*"
							  RowSpacing="6">
							<TextBlock Text="节点" Foreground="#7ec8ff" FontWeight="Bold"/>
							<TreeView Grid.Row="1"
									  ItemsSource="{Binding Tree.NodeToolGroups}"
									  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
									  ScrollViewer.VerticalScrollBarVisibility="Auto"
									  HorizontalAlignment="Stretch"
									  VerticalAlignment="Stretch">
								<TreeView.DataTemplates>
									<TreeDataTemplate DataType="vm:NodeToolGroupViewModel" ItemsSource="{Binding Tools}">
										<TextBlock Text="{Binding Name}"
												   FontWeight="SemiBold"
												   TextWrapping="Wrap"/>
									</TreeDataTemplate>
									<DataTemplate DataType="vm:NodeToolViewModel">
										<Border Padding="6,4"
												CornerRadius="3"
												Background="Transparent"
												HorizontalAlignment="Stretch"
												PointerPressed="NodeTool_PointerPressed">
											<StackPanel>
												<TextBlock Text="{Binding Name}"
														   FontWeight="SemiBold"
														   TextWrapping="Wrap"/>
												<TextBlock Text="{Binding Description}"
														   Opacity="0.68"
														   FontSize="11"
														   TextWrapping="Wrap"
														   HorizontalAlignment="Stretch"/>
											</StackPanel>
										</Border>
									</DataTemplate>
								</TreeView.DataTemplates>
							</TreeView>
						</Grid>
					</Border>

					<!-- Agent 模型 -->
					<Border Grid.Row="1"
							Padding="10"
							Background="Transparent"
							BorderBrush="#4c4c4c"
							BorderThickness="1"
							CornerRadius="4">
						<StackPanel Spacing="7">
							<TextBlock Text="Agent 模型" Foreground="#7ec8ff" FontWeight="Bold"/>

							<Grid ColumnDefinitions="88,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
								<TextBlock Grid.Row="0"
										   Grid.Column="0"
										   Text="API Key 环境变量"
										   Opacity="0.68"
										   FontSize="11"
										   VerticalAlignment="Center"/>
								<TextBox Grid.Row="0"
										 Grid.Column="1"
										 Text="{Binding Tree.EnvironmentVariableName, Mode=TwoWay}"
										 PlaceholderText="OPENAI_API_KEY"
										 FontSize="11"/>

								<TextBlock Grid.Row="1"
										   Grid.Column="0"
										   Text="Endpoint"
										   Opacity="0.68"
										   FontSize="11"
										   VerticalAlignment="Center"/>
								<TextBox Grid.Row="1"
										 Grid.Column="1"
										 Text="{Binding Tree.Endpoint, Mode=TwoWay}"
										 PlaceholderText="https://api.openai.com/v1"
										 FontSize="11"/>

								<TextBlock Grid.Row="2"
										   Grid.Column="0"
										   Text="Model"
										   Opacity="0.68"
										   FontSize="11"
										   VerticalAlignment="Center"/>
								<TextBox Grid.Row="2"
										 Grid.Column="1"
										 Text="{Binding Tree.Model, Mode=TwoWay}"
										 PlaceholderText="gpt-4.1-mini"
										 FontSize="11"/>
							</Grid>
						</StackPanel>
					</Border>

					<!-- Agent 对话 -->
					<Border Grid.Row="2"
							Padding="10"
							Background="Transparent"
							BorderBrush="#4c4c4c"
							BorderThickness="1"
							CornerRadius="4">
						<Grid RowDefinitions="Auto,*,Auto"
							  RowSpacing="6">
							<Grid ColumnDefinitions="*,Auto">
								<TextBlock Text="Agent 对话" Foreground="#7ec8ff" FontWeight="Bold"/>
								<ToggleSwitch Grid.Column="1"
											  IsChecked="{Binding Tree.UseStreamingAgentResponse}"
											  OnContent="流式"
											  OffContent="普通"
											  FontSize="11"
											  Margin="0,-6,0,-6"/>
							</Grid>

							<Border Grid.Row="1">
								<views:MarkdownView DataContext="{Binding Tree.AgentTranscriptDocument}"
													AutoScrollToEnd="True"/>
							</Border>

							<Grid Grid.Row="2"
								  ColumnDefinitions="*,Auto">
								<TextBox x:Name="AgentInput"
										 Grid.Column="0"
										 IsEnabled="{Binding !Tree.HasPendingAgentInteraction}"
										 AcceptsReturn="False"/>
								<Button Grid.Column="1"
										Content="发送"
										Margin="4,0,0,0"
										IsVisible="{Binding !Tree.IsAgentRequestRunning}"
										IsEnabled="{Binding !Tree.HasPendingAgentInteraction}"
										Click="Ask_Click"/>
								<Button Grid.Column="1"
										Content="取消"
										Margin="4,0,0,0"
										IsVisible="{Binding Tree.IsAgentRequestRunning}"
										Command="{Binding Tree.CancelAgentRequestCommand}"/>
							</Grid>
						</Grid>
					</Border>

					<!-- Agent 检查点 -->
					<Border Grid.Row="3"
							Padding="10"
							Background="Transparent"
							BorderBrush="#4c4c4c"
							BorderThickness="1"
							CornerRadius="4">
						<Grid RowDefinitions="Auto,*"
							  RowSpacing="7">
							<Grid ColumnDefinitions="*,Auto">
								<TextBlock Text="检查点" Foreground="#7ec8ff" FontWeight="Bold"/>
								<TextBlock Grid.Column="1"
										   Text="{Binding Tree.AgentCheckpoints.Count}"
										   Opacity="0.65"
										   FontSize="11"/>
							</Grid>
							<ScrollViewer Grid.Row="1"
										  VerticalScrollBarVisibility="Auto"
										  HorizontalScrollBarVisibility="Disabled">
								<ItemsControl ItemsSource="{Binding Tree.AgentCheckpoints}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Spacing="4"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="vm:AgentCheckpointViewModel">
											<Expander IsExpanded="False"
													  Background="Transparent"
													  HorizontalAlignment="Stretch"
													  HorizontalContentAlignment="Stretch">
												<Expander.Header>
													<TextBlock Text="{Binding CreatedAtText}"
															   Opacity="0.72"
															   FontSize="11"/>
												</Expander.Header>
												<StackPanel Spacing="7" Margin="8,2,8,8">
													<TextBlock Text="{Binding Summary}"
															   TextWrapping="Wrap"/>
													<Grid ColumnDefinitions="*,Auto">
														<TextBlock Text="{Binding SnapshotSizeText}"
																   Opacity="0.65"
																   FontSize="10"
																   VerticalAlignment="Center"/>
														<Button Grid.Column="1"
																Content="切换到此状态"
																Click="RestoreCheckpoint_Click"/>
													</Grid>
												</StackPanel>
											</Expander>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
						</Grid>
					</Border>
			</Grid>

			<GridSplitter Grid.Column="1" Background="#01000000"/>

			<Grid Grid.Column="2">
				<views:TreeView DataContext="{Binding Tree}"/>

				<Grid IsVisible="{Binding Tree.HasPendingAgentInteraction}">
					<Border IsVisible="{Binding Tree.HasPendingAgentSelection}"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Center"
							MaxWidth="520"
							Margin="24"
							Background="#F2181818"
							BorderBrush="#4c4c4c"
							BorderThickness="1"
							CornerRadius="4"
							Padding="16">
						<StackPanel Spacing="10">
							<TextBlock Text="AI 发起选择"
									   Foreground="#7ec8ff"
									   FontWeight="Bold"
									   FontSize="16"/>
							<TextBlock Text="{Binding Tree.AgentSelectionPrompt}"
									   Foreground="#d8d8d8"
									   TextWrapping="Wrap"/>
							<ScrollViewer MaxHeight="280"
										  VerticalScrollBarVisibility="Auto">
								<ItemsControl ItemsSource="{Binding Tree.AgentSelectionOptions}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Spacing="6"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="vm:AgentSelectionOptionViewModel">
											<RadioButton GroupName="AgentSelectionOptions"
														 Content="{Binding Text}"
														 IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
							<StackPanel Orientation="Horizontal"
										Spacing="6"
										HorizontalAlignment="Right">
								<Button Content="取消"
										Command="{Binding Tree.CancelAgentSelectionCommand}"/>
								<Button Content="提交选择"
										Command="{Binding Tree.SubmitAgentSelectionCommand}"/>
							</StackPanel>
						</StackPanel>
					</Border>

					<Border IsVisible="{Binding Tree.HasPendingAgentConfirmation}"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Center"
							MaxWidth="520"
							Margin="24"
							Background="#F2181818"
							BorderBrush="#66552d"
							BorderThickness="1"
							CornerRadius="4"
							Padding="16">
						<StackPanel Spacing="10">
							<TextBlock Text="AI 操作确认"
									   Foreground="#ffd166"
									   FontWeight="Bold"
									   FontSize="16"/>
							<Border Background="#2a1f00"
									BorderBrush="#66552d"
									BorderThickness="1"
									CornerRadius="3"
									Padding="8,6">
								<TextBlock Text="{Binding Tree.AgentConfirmationOperationKey}"
										   Foreground="#ffd166"
										   FontFamily="Consolas"
										   FontSize="11"
										   TextWrapping="Wrap"/>
							</Border>
							<TextBlock Text="{Binding Tree.AgentConfirmationDescription}"
									   Foreground="#d8d8d8"
									   TextWrapping="Wrap"/>
							<StackPanel Spacing="6">
								<RadioButton GroupName="AgentConfirmationOptions"
											 Content="拒绝"
											 IsChecked="{Binding Tree.AgentConfirmationDenySelected, Mode=TwoWay}"/>
								<RadioButton GroupName="AgentConfirmationOptions"
											 Content="仅同意一次"
											 IsChecked="{Binding Tree.AgentConfirmationAllowOnceSelected, Mode=TwoWay}"/>
								<RadioButton GroupName="AgentConfirmationOptions"
											 Content="本次会话始终同意"
											 IsChecked="{Binding Tree.AgentConfirmationAllowAlwaysSelected, Mode=TwoWay}"/>
							</StackPanel>
							<Button Content="提交决定"
									HorizontalAlignment="Right"
									Command="{Binding Tree.SubmitAgentConfirmationCommand}"/>
						</StackPanel>
					</Border>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</UserControl>







